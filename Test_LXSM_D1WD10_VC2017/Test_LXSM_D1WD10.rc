/////////////////////////////////////////////////////////////////////////////
//
// Menu
//

IDR_MAINFRAME MENU
BEGIN
    POPUP "파일(&F)"
    BEGIN
        MENUITEM "새 파일(&N)\tCtrl+N",            ID_FILE_NEW
        MENUITEM "열기(&O)...\tCtrl+O",           ID_FILE_OPEN
        MENUITEM "저장(&S)\tCtrl+S",              ID_FILE_SAVE
        MENUITEM "다른 이름으로 저장(&A)...",           ID_FILE_SAVE_AS
        MENUITEM SEPARATOR
        MENUITEM "최근 파일",                       ID_FILE_MRU_FILE1, GRAYED
        MENUITEM SEPARATOR
        MENUITEM "종료(&X)",                      ID_APP_EXIT
    END
    POPUP "기기제어"
    BEGIN
        POPUP "Init_Device (제품별로 다름)"
        BEGIN
            MENUITEM "PolyG-A",                     ID_MENU_InitDevice_PolyG_A
            MENUITEM "PolyG-I",                     ID_MENU_InitDevice_PolyG_I
        END
        POPUP "Set_ADCMaxNumChannel"
        BEGIN
            MENUITEM "최대32채널",                      ID_MENU_SetADCMaxNumCh_32
            MENUITEM "최대16채널",                      ID_MENU_SetADCMaxNumCh_16
            MENUITEM "최대8채널",                       ID_MENU_SetADCMaxNumCh_8
            MENUITEM "최대4채널",                       ID_MENU_SetADCMaxNumCh_4
            MENUITEM "최대2채널",                       ID_MENU_SetADCMaxNumCh_2
        END
        POPUP "Set_SampleFrequency"
        BEGIN
            MENUITEM "128Hz",                       ID_MENU_SetSample_128
            MENUITEM "256Hz",                       ID_MENU_SetSample_256
            MENUITEM "512Hz",                       ID_MENU_SetSample_512
            MENUITEM "1024Hz",                      ID_MENU_SetSample_1024
            MENUITEM "2048Hz",                      ID_MENU_SetSample_2048
            MENUITEM "4096Hz",                      ID_MENU_SetSample_4096
        END
        MENUITEM "Set_PGA_SourceGroup...",      ID_MENU_Set_PGA_SourceGroup
        MENUITEM "Start_Stream",                ID_MENU_Start_Stream
        MENUITEM "Stop_Stream",                 ID_MENU_Stop_Stream
        MENUITEM "Close_Device",                ID_MENU_Close_Device
    END
    POPUP "도움말(&H)"
    BEGIN
        MENUITEM "Test_LXSM_D1WD10 정보(&A)...",  ID_APP_ABOUT
    END
END


